@app.route('/')
def home():
    """
    Homepage with search functionality and movie listings
    """
    conn = sqlite3.connect('database/movies.db')
    cursor = conn.cursor()
    
    # Get all movies for display
    cursor.execute('''
        SELECT id, title, genre, description, poster_url, rating, duration
        FROM movies
        ORDER BY title
    ''')
    
    movies = cursor.fetchall()
    conn.close()
    
    return render_template('home.html', movies=movies)

@app.route('/search')
def search():
    """
    Search for movies
    """
    query = request.args.get('q', '')
    if not query:
        return redirect(url_for('home'))
    
    # Use the AI recommender to search movies
    if not recommender.movies_df is not None:
        recommender.load_movies_from_db()
    
    search_results = recommender.search_movies(query)
    
    return render_template('home.html', movies=search_results, search_query=query)

@app.route('/movie/<int:movie_id>')
def movie_details(movie_id):
    """
    Movie details page with recommendations and booking options
    """
    conn = sqlite3.connect('database/movies.db')
    cursor = conn.cursor()
    
    # Get movie details
    cursor.execute('SELECT * FROM movies WHERE id = ?', (movie_id,))
    movie = cursor.fetchone()
    
    if not movie:
        flash('Movie not found!', 'error')
        return redirect(url_for('home'))
    
    # Get showtimes for this movie
    cursor.execute('''
        SELECT s.id, s.show_date, s.show_time, s.price, t.name as theatre_name, t.location
        FROM showtimes s
        JOIN theatres t ON s.theatre_id = t.id
        WHERE s.movie_id = ? AND s.show_date >= DATE('now')
        ORDER BY s.show_date, s.show_time
    ''', (movie_id,))
    
    showtimes = cursor.fetchall()
    conn.close()
    
    return render_template('movie_details.html', movie=movie, showtimes=showtimes)

@app.route('/recommendations/<int:movie_id>')
def get_recommendations(movie_id):
    """
    Get AI-powered movie recommendations
    """
    conn = sqlite3.connect('database/movies.db')
    cursor = conn.cursor()
    
    # Get movie title
    cursor.execute('SELECT title FROM movies WHERE id = ?', (movie_id,))
    movie = cursor.fetchone()
    conn.close()
    
    if not movie:
        flash('Movie not found!', 'error')
        return redirect(url_for('home'))
    
    # Initialize recommender if not already done
    if not recommender.movies_df is not None:
        if not recommender.initialize_system():
            flash('Recommendation system not available', 'error')
            return redirect(url_for('movie_details', movie_id=movie_id))
    
    # Get recommendations
    recommendations = recommender.get_recommendations(movie[0], top_n=5)
    
    # Ensure recommendations is always a list
    if not recommendations:
        recommendations = []
    
    return render_template('recommendation.html', 
                         movie_title=movie[0], 
                         recommendations=recommendations)

@app.route('/booking/<int:showtime_id>')
def booking(showtime_id):
    """
    Seat selection and booking page
    """
    conn = sqlite3.connect('database/movies.db')
    cursor = conn.cursor()
    
    # Get showtime details
    cursor.execute('''
        SELECT s.*, m.title, m.poster_url, t.name as theatre_name, t.location
        FROM showtimes s
        JOIN movies m ON s.movie_id = m.id
        JOIN theatres t ON s.theatre_id = t.id
        WHERE s.id = ?
    ''', (showtime_id,))
    
    showtime = cursor.fetchone()
    
    if not showtime:
        flash('Showtime not found!', 'error')
        return redirect(url_for('home'))
    
    # Get seat availability
    cursor.execute('''
        SELECT seat_number, is_booked
        FROM seats
        WHERE showtime_id = ?
        ORDER BY seat_number
    ''', (showtime_id,))
    
    seats = cursor.fetchall()
    conn.close()
    
    return render_template('booking.html', showtime=showtime, seats=seats)

@app.route('/api/book_seats', methods=['POST'])
def book_seats():
    """
    API endpoint to book seats
    """
    data = request.json
    showtime_id = data['showtime_id']
    selected_seats = data['seats']
    customer_name = data['customer_name']
    customer_email = data['customer_email']
    payment_method = data['payment_method']
    
    conn = sqlite3.connect('database/movies.db')
    cursor = conn.cursor()
    
    try:
        # Get showtime details for pricing
        cursor.execute('SELECT price FROM showtimes WHERE id = ?', (showtime_id,))
        price_per_seat = cursor.fetchone()[0]
        total_amount = price_per_seat * len(selected_seats)
        
        # Create booking
        cursor.execute('''
            INSERT INTO bookings (movie_id, showtime_id, seat_numbers, total_amount, payment_method, customer_name, customer_email)
            VALUES ((SELECT movie_id FROM showtimes WHERE id = ?), ?, ?, ?, ?, ?, ?)
        ''', (showtime_id, showtime_id, ','.join(selected_seats), total_amount, payment_method, customer_name, customer_email))
        
        booking_id = cursor.lastrowid
        
        # Mark seats as booked
        for seat in selected_seats:
            cursor.execute('''
                UPDATE seats SET is_booked = TRUE, booking_id = ?
                WHERE showtime_id = ? AND seat_number = ?
            ''', (booking_id, showtime_id, seat))
        
        conn.commit()
        
        return jsonify({
            'success': True,
            'booking_id': booking_id,
            'total_amount': total_amount
        })
        
    except Exception as e:
        conn.rollback()
        return jsonify({'success': False, 'error': str(e)})
    
    finally:
        conn.close()

@app.route('/confirmation/<int:booking_id>')
def confirmation(booking_id):
    """
    Booking confirmation page with QR code
    """
    conn = sqlite3.connect('database/movies.db')
    cursor = conn.cursor()
    
    # Get booking details
    cursor.execute('''
        SELECT b.*, m.title, m.poster_url, t.name as theatre_name, t.location,
               s.show_date, s.show_time, s.price
        FROM bookings b
        JOIN movies m ON b.movie_id = m.id
        JOIN theatres t ON s.theatre_id = t.id
        JOIN showtimes s ON b.showtime_id = s.id
        WHERE b.id = ?
    ''', (booking_id,))
    
    booking = cursor.fetchone()
    conn.close()
    
    if not booking:
        flash('Booking not found!', 'error')
        return redirect(url_for('home'))
    
    # Generate QR code
    qr_data = f"""
ShowKaalam - When It's Showtime, It's ShowKaalam

Movie: {booking[7]}
Theatre: {booking[8]}
Date: {booking[11]}
Time: {booking[12]}
Seats: {booking[3]}
Total: ₹{booking[4]}
Booking ID: {booking[0]}
    """.strip()
    
    qr = qrcode.QRCode(version=1, box_size=10, border=5)
    qr.add_data(qr_data)
    qr.make(fit=True)
    
    img = qr.make_image(fill_color="black", back_color="white")
    
    # Convert to base64 for HTML display
    buffer = io.BytesIO()
    img.save(buffer, format='PNG')
    buffer.seek(0)
    qr_code_base64 = base64.b64encode(buffer.getvalue()).decode()
    
    return render_template('confirmation.html', booking=booking, qr_code=qr_code_base64)

